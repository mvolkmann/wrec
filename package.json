{
  "name": "wrec",
  "version": "0.42.2",
  "description": "a library that greatly simplifies building web components",
  "keywords": [
    "component",
    "web"
  ],
  "license": "MIT",
  "author": "R. Mark Volkmann",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mvolkmann/wrec.git"
  },
  "bin": {
    "wrec-declare": "./scripts/declare.js",
    "wrec-lint": "./scripts/lint.js",
    "wrec-scaffold": "./scripts/scaffold.js",
    "wrec-usedby": "./scripts/used-by.js"
  },
  "files": [
    "dist",
    "scripts/ast-utils.js",
    "scripts/declare.js",
    "scripts/lint.js",
    "scripts/scaffold.js",
    "scripts/template.ts",
    "scripts/used-by.js",
    "README.md"
  ],
  "type": "module",
  "module": "./dist/wrec.es.js",
  "types": "./dist/wrec.d.ts",
  "exports": {
    ".": {
      "types": "./dist/wrec.d.ts",
      "browser": "./dist/wrec.es.js",
      "node": "./dist/wrec-ssr.es.js",
      "default": "./dist/wrec.es.js"
    },
    "./ssr": {
      "types": "./dist/wrec-ssr.d.ts",
      "import": "./dist/wrec-ssr.es.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "clean": "rm -rf dist",
    "format": "oxfmt",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "node port-check.js && playwright test",
    "testui": "playwright test --ui",
    "unittest": "vitest run"
  },
  "dependencies": {
    "node-html-parser": "^7.1.0",
    "typescript": "^6.0.3",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "get-port": "^7.2.0",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.5.2",
  "moduleResolution": "bundler"
}
